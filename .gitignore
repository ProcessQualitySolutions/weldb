# Python
__pycache__/
*.py[cod]
*.egg-info/
*.egg-info
dist/
build/
.venv/
*.egg
.ruff_cache/
.pytest_cache/

# Claude Code (local, machine-specific)
.claude/settings.local.json

# Editors
.idea/
.vscode/

# OS
.DS_Store
Thumbs.db
desktop.ini

# Generated example PDFs (rendered on demand, keep the repo light)
examples/**/*.pdf
examples/*.pdf

# Local example render helper (run on demand, not part of the library)
examples/render_all_examples.py

# Personal scratch notes
__temp*.txt

# Dev/test scratch scripts — must never be committed or shipped with the hosted
# server. Root-anchored (leading /) so the real suite under tests/ stays tracked.
/test_*.py
/*_test.py
/scratch_*.py
/scratch_*/
/tmp_*.py

# Generated artifacts, in case the repo root is ever used as a project folder
# during local dev. The server writes these into the user's project_path, never
# into the code tree — this keeps a stray dev render from being committed.
/*.pdf
/*_weld_positions.json
/point_welds.csv
/linear_welds.csv
/area_welds.csv
